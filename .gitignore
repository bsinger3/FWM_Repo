# macOS
.DS_Store
__pycache__/
*.pyc

# Local tool/cache directories
.claude/
.codex_tmp/
.codex_vendor/
.playwright-browsers/
.wrangler/
.npm-cache/
node_modules/
.venv*/
*.py[cod]
playwright-report/
supabase/.temp/
test-results/

# Scraping data and generated pipeline artifacts live outside this repo.
# See DATA.md for the local directory and S3 backup workflow.
_active_scrape_claims/*.claim
!_active_scrape_claims/missacc_com.claim
data-pipelines/**/data
data-pipelines/**/data/
data-pipelines/**/models
data-pipelines/**/models/
_preserved_local_before_sync_*/

# Local model weights and downloaded ML assets
*.pt
*.onnx
*.caffemodel

# Local environment/secrets
.env
.env.*
!.env.example

# NOTE: index.dev.html + config.dev.js (the dev-database preview) are now tracked
# so the frontend work has version history and is shareable. They must be kept
# OUT of the Cloudflare Pages deploy (they point at the dev DB) via a Pages build
# command that strips them, e.g. `rm -f index.dev.html config.dev.js`. Until that
# is configured, do not push to main expecting them to stay private.

# Codex transcript artifacts are uploaded to Supabase, not stored in Git.
codex-*.json
codex-chat-transcript*.json
codex-*transcript*.json

# Generated product_pages working copy (regenerate via scripts/export-product-pages-working-copy.mjs)
data-pipelines/products/product_pages_working_copy.csv
data-pipelines/products/product_pages_working_copy.ndjson

# Manual taxonomy review decisions (personal review output; lives in repo but not versioned)
data-pipelines/products/manual_taxonomy_review/*.ndjson
data-pipelines/products/manual_taxonomy_review/*.json

# Local Google Analytics exports/snapshots (analysis artifacts; keep out of repo)
GoogleAnalytics/

# Scrape response caches (regenerable; thousands of files — keep out of repo)
**/.title-scrape-cache/
