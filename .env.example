# Copy this to .env and fill in your machine-local data path and private S3 bucket name.
# Mac example:
# FWM_DATA_DIR=/Users/briannasinger/Projects/FWM/FWM_Data
# Windows example:
FWM_DATA_DIR=C:/Users/bsing/OneDrive/Documents/Projects/FWM/FWM_Data
FWM_S3_BUCKET=s3://your-private-fwm-data-bucket
FWM_AWS_PROFILE=fwm

# Needed for dev-only Supabase loaders, backfills, and Codex transcript uploads.
# The dev images-table refresh guard only allows this dev project URL.
SUPABASE_URL=https://gosqgqpftqlawvnyelkt.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional colon-separated list of extra reviewed-workbook package directories for dev loader source resolution.
# FWM_IMAGE_REVIEW_ADDITIONAL_PACKAGE_DIRS=/absolute/path/package_a:/absolute/path/package_b
# Optional explicit duplicate-skip override for dev approved-image loader apply after reviewing dry-run conflicts.
# FWM_DEV_IMAGE_LOAD_SKIP_DUPLICATE_CONFLICTS=yes-reviewed-dry-run
# Needed only for pg_dump/psql baseline restore workflows. Must point to dev for restore.
DEV_DATABASE_URL=postgresql://postgres.gosqgqpftqlawvnyelkt:your-password@aws-0-us-east-1.pooler.supabase.com:5432/postgres
# Needed only for the read-only production public.images baseline export.
PROD_DATABASE_URL=postgresql://postgres.kmomndloorvrjzmiexxl:your-password@aws-0-us-east-1.pooler.supabase.com:5432/postgres
OPENAI_API_KEY=your-openai-api-key
# Optional. Inference: this defaults to gpt-5.2 because that is shown in current OpenAI Responses API examples.
# OPENAI_MODEL=gpt-5.2

# Sovrn Commerce.
# The JavaScript campaign key is public and belongs in config.js at window.SOVRN_COMMERCE.key.
# Keep the API secret server-side only; use it from scripts or a future backend/Edge Function.
SOVRN_COMMERCE_API_SECRET=your-sovrn-commerce-api-secret
# Amazon Associates tracking tag. Append as ?tag=<value> to amazon.com /dp/{ASIN} URLs.
AMAZON_ASSOCIATES_TAG=your-amazon-associates-tag

# Reddit API (script app) for harvesting subreddit posts with measurements + photos.
# Create a "script" app at https://www.reddit.com/prefs/apps (redirect uri http://localhost:8080).
# client_id is the string under the app name; secret is the "secret" field.
# Username/password are the account the script authenticates as (read-only use).
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USERNAME=your-reddit-username
REDDIT_PASSWORD=your-reddit-password
# Reddit requires a descriptive, unique User-Agent: "<platform>:<appid>:<version> (by /u/<username>)"
REDDIT_USER_AGENT=script:fwm-research:0.1 (by /u/your-reddit-username)
